@model SistemaGestionAcademica.Web.Models.Usuario
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row">
    <div class="col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 col-lg-6 offset-lg-3 col-xl-4 offset-xl-4">
        <div class="login-brand">
            <a asp-action="Dashboard" asp-controller="Home">
                <img src="/img/stisla.pmg" alt="logo" width="100" class="shadow-light rounded-circle">
            </a>
        </div>

        <div class="card card-primary">
            <div class="card-header"><h4>Iniciar Sesión</h4></div>

            <div class="card-body">
                <!-- Mensaje de error si las credenciales son inválidas -->
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Index" asp-controller="Home" method="post" class="needs-validation" novalidate>
                    <div class="form-group">
                        <label asp-for="Correo">Correo Electrónico</label>
                        <input asp-for="Correo" class="form-control" type="email" required autofocus />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="d-block">
                            <label asp-for="Contrasena" class="control-label">Contraseña</label>
                            <div class="float-right">
                                <a asp-action="Recuperar" asp-controller="Home" class="text-small">¿Olvidaste tu contraseña?</a>
                            </div>
                        </div>
                        <input asp-for="Contrasena" class="form-control" type="password" required />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary btn-lg btn-block">Ingresar</button>
                    </div>
                </form>

                <div class="text-center mt-4 mb-3">
                    <div class="text-job text-muted">Iniciar sesión con</div>
                </div>
                <div class="row sm-gutters">
                    <div class="col-6">
                        <a class="btn btn-block btn-social btn-facebook">
                            <span class="fab fa-facebook"></span> Facebook
                        </a>
                    </div>
                    <div class="col-6">
                        <a class="btn btn-block btn-social btn-twitter">
                            <span class="fab fa-twitter"></span> Twitter
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 text-muted text-center">
            ¿No tiene una cuenta?
            <a asp-action="Registro" asp-controller="Home" class="font-bold">Crear Cuenta</a>
        </div>
        <div class="simple-footer">
            <p style="text-align: center;">
                @DateTime.Now.Year &copy; Stisla
            </p>
        </div>
    </div>
</div>
