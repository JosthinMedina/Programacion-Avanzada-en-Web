@model IEnumerable<SistemaGestionAcademica.Web.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">

                Gestión de Usuarios

            </h2>

            <small class="text-muted">

                Administración de los usuarios del sistema.

            </small>

        </div>

        <a asp-action="Registrar"
           class="btn btn-primary">

            + Nuevo Usuario

        </a>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>ID</th>

                        <th>Correo</th>

                        <th>Rol</th>

                        <th>Estado</th>

                        <th>Fecha Registro</th>

                        <th width="180">

                            Acciones

                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                @item.IdUsuario

                            </td>

                            <td>

                                @item.Correo

                            </td>

                            <td>

                                @item.NombreRol

                            </td>

                            <td>

                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">

                                        Activo

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">

                                        Inactivo

                                    </span>
                                }

                            </td>

                            <td>

                                @item.FechaRegistro.ToString("dd/MM/yyyy")

                            </td>

                            <td>

                                <a asp-action="Editar"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-warning btn-sm">

                                    Editar

                                </a>

                                <a asp-action="Eliminar"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('¿Desea desactivar este usuario?');">

                                    Eliminar

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
