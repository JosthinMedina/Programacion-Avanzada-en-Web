@model IEnumerable<SistemaGestionAcademica.Web.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Administración de usuarios</h2>
            <p class="text-muted mb-0">
                Consulta y administra los usuarios registrados en el sistema.
            </p>
        </div>

        <a asp-controller="Usuarios"
           asp-action="Registrar"
           class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-1"></i>
            Nuevo usuario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-semibold">
                Lista de usuarios
            </h5>
        </div>

        <div class="card-body p-0">

            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people fs-1 text-muted"></i>

                    <h5 class="mt-3">
                        No hay usuarios registrados
                    </h5>

                    <p class="text-muted">
                        Registra el primer usuario del sistema.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Correo</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Fecha de registro</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var usuario in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @usuario.IdUsuario
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-primary-subtle text-primary d-flex justify-content-center align-items-center me-3"
                                                 style="width: 40px; height: 40px;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>

                                            <div>
                                                <span class="fw-semibold">
                                                    @usuario.Correo
                                                </span>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary-subtle text-secondary">
                                            @usuario.NombreRol
                                        </span>
                                    </td>

                                    <td>
                                        @if (usuario.Estado)
                                        {
                                            <span class="badge bg-success-subtle text-success">
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger">
                                                Inactivo
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @usuario.FechaRegistro.ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="text-center">
                                        <a asp-controller="Usuarios"
                                           asp-action="Editar"
                                           asp-route-id="@usuario.IdUsuario"
                                           class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        @if (usuario.Estado)
                                        {
                                            <a asp-controller="Usuarios"
                                               asp-action="Eliminar"
                                               asp-route-id="@usuario.IdUsuario"
                                               class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-person-x-fill"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>
