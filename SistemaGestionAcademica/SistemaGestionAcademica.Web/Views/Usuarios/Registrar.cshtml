@model SistemaGestionAcademica.Web.Models.Usuario

@{
    ViewData["Title"] = "Registrar Usuario";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        Registrar Usuario
                    </h4>
                </div>

                <div class="card-body">

                    <form asp-action="Registrar">

                        <div class="mb-3">

                            <label asp-for="IdRol" class="form-label">
                                Rol
                            </label>

                            <select asp-for="IdRol" class="form-select">

                                <option value="">Seleccione...</option>

                                <option value="1">Administrador</option>

                                <option value="2">Profesor</option>

                                <option value="3">Estudiante</option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Correo" class="form-label">
                                Correo
                            </label>

                            <input asp-for="Correo"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Contrasena" class="form-label">
                                Contraseña
                            </label>

                            <input asp-for="Contrasena"
                                   type="password"
                                   class="form-control" />

                        </div>

                        <div class="d-grid gap-2">

                            <button type="submit"
                                    class="btn btn-success">

                                Guardar Usuario

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                Regresar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>