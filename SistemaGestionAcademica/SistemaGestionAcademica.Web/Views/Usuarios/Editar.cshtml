@model SistemaGestionAcademica.Web.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow border-0">

                <div class="card-header bg-warning">
                    <h4 class="mb-0">
                        Editar Usuario
                    </h4>
                </div>

                <div class="card-body">

                    <form asp-action="Editar">

                        <input asp-for="IdUsuario" type="hidden" />

                        <div class="mb-3">

                            <label asp-for="IdRol" class="form-label">
                                Rol
                            </label>

                            <select asp-for="IdRol" class="form-select">

                                <option value="1">Administrador</option>
                                <option value="2">Profesor</option>
                                <option value="3">Estudiante</option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Correo" class="form-label">
                                Correo
                            </label>

                            <input asp-for="Correo"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Contrasena" class="form-label">
                                Contraseña
                            </label>

                            <input asp-for="Contrasena"
                                   type="password"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Estado" class="form-label">
                                Estado
                            </label>

                            <select asp-for="Estado"
                                    class="form-select">

                                <option value="true">
                                    Activo
                                </option>

                                <option value="false">
                                    Inactivo
                                </option>

                            </select>

                        </div>

                        <div class="d-grid gap-2">

                            <button class="btn btn-warning">

                                Actualizar Usuario

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>