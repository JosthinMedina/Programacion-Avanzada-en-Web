<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Sistema Gestión Académica</title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/SistemaGestionAcademica.Web.styles.css"
          asp-append-version="true" />

</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">

        <div class="container-fluid">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">

                🎓 Sistema Gestión Académica

            </a>

        </div>

    </nav>

    <div class="container-fluid">

        <div class="row">

            <aside class="col-md-2 bg-dark text-white min-vh-100 p-0">

                <div class="p-3">

                    <h5 class="text-center">

                        Menú

                    </h5>

                    <hr class="text-secondary"/>

                    <div class="list-group list-group-flush">

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-house-fill me-2"></i>

                            Inicio

                        </a>

                        <a asp-controller="Usuarios"
                           asp-action="Index"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-people-fill me-2"></i>

                            Usuarios

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-mortarboard-fill me-2"></i>

                            Estudiantes

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-person-workspace me-2"></i>

                            Profesores

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-book-fill me-2"></i>

                            Cursos

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-journal-check me-2"></i>

                            Matrículas

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-clipboard-data-fill me-2"></i>

                            Calificaciones

                        </a>

                        <a href="#"
                           class="list-group-item list-group-item-action bg-dark text-white border-0">

                            <i class="bi bi-calendar-event-fill me-2"></i>

                            Eventos

                        </a>

                    </div>

                </div>

            </aside>

            <main class="col-md-10 p-4">

                @RenderBody()

            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>