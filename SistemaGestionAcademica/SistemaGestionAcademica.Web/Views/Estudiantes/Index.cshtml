@model IEnumerable<SistemaGestionAcademica.Web.Models.Estudiante>

@{
    ViewData["Title"] = "Estudiantes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Estudiantes</h2>

    <a asp-action="Registrar" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i>
        Nuevo Estudiante
    </a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Primer Apellido</th>
            <th>Segundo Apellido</th>
            <th>Identificación</th>
            <th>Correo</th>
            <th>Teléfono</th>
            <th>Estado</th>
            <th width="180"></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Nombre</td>

                <td>@item.PrimerApellido</td>

                <td>@item.SegundoApellido</td>

                <td>@item.Identificacion</td>

                <td>@item.Correo</td>

                <td>@item.Telefono</td>

                <td>

                    @if (item.Estado)
                    {
                        <span class="badge bg-success">
                            Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inactivo
                        </span>
                    }

                </td>

                <td>

                    <a asp-action="Editar"
                       asp-route-id="@item.IdEstudiante"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Eliminar"
                       asp-route-id="@item.IdEstudiante"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('¿Desea eliminar este estudiante?')">
                        Eliminar
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>
