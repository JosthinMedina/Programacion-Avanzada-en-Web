@model IEnumerable<SistemaGestionAcademica.Web.Models.Profesor>

@{
    ViewData["Title"] = "Profesores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Profesores</h2>

    <a asp-action="Registrar" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i>
        Nuevo Profesor
    </a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Identificación</th>
            <th>Correo</th>
            <th>Teléfono</th>
            <th>Especialidad</th>
            <th>Estado</th>
            <th width="180"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>

                <td>
                    @item.PrimerApellido @item.SegundoApellido
                </td>

                <td>@item.Identificacion</td>

                <td>@item.Correo</td>

                <td>@item.Telefono</td>

                <td>@item.Especialidad</td>

                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">
                            Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inactivo
                        </span>
                    }
                </td>

                <td>
                    <a asp-action="Editar"
                       asp-route-id="@item.IdProfesor"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Eliminar"
                       asp-route-id="@item.IdProfesor"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('¿Desea eliminar este profesor?')">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
