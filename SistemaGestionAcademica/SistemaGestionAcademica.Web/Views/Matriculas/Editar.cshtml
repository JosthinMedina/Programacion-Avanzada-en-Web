@model SistemaGestionAcademica.Web.Models.Matricula

@{
    ViewData["Title"] = "Editar Matrícula";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow border-0">

                <div class="card-header bg-warning">

                    <h4 class="mb-0">
                        Editar Matrícula
                    </h4>

                </div>

                <div class="card-body">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Editar"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input asp-for="IdMatricula"
                               type="hidden" />

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-3">

                            <label asp-for="IdEstudiante"
                                   class="form-label">
                            </label>

                            <select asp-for="IdEstudiante"
                                    asp-items="ViewBag.Estudiantes"
                                    class="form-select">

                                <option value="">
                                    Seleccione un estudiante
                                </option>

                            </select>

                            <span asp-validation-for="IdEstudiante"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="IdCurso"
                                   class="form-label">
                            </label>

                            <select asp-for="IdCurso"
                                    asp-items="ViewBag.Cursos"
                                    class="form-select">

                                <option value="">
                                    Seleccione un curso
                                </option>

                            </select>

                            <span asp-validation-for="IdCurso"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="FechaMatricula"
                                   class="form-label">
                            </label>

                            <input asp-for="FechaMatricula"
                                   type="date"
                                   class="form-control" />

                            <span asp-validation-for="FechaMatricula"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Estado"
                                   class="form-label">
                            </label>

                            <select asp-for="Estado"
                                    class="form-select">

                                <option value="true">
                                    Activa
                                </option>

                                <option value="false">
                                    Inactiva
                                </option>

                            </select>

                        </div>

                        <div class="d-grid gap-2">

                            <button type="submit"
                                    class="btn btn-warning">

                                <i class="bi bi-save me-1"></i>

                                Actualizar Matrícula

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }
}