@model IEnumerable<SistemaGestionAcademica.Web.Models.Calificacion>

@using SistemaGestionAcademica.Web.Models

@{
    ViewData["Title"] = "Calificaciones";

    var matriculas =
        ViewBag.Matriculas as List<Matricula>
        ?? new List<Matricula>();

    var estudiantes =
        ViewBag.Estudiantes as List<Estudiante>
        ?? new List<Estudiante>();

    var cursos =
        ViewBag.Cursos as List<Curso>
        ?? new List<Curso>();
}

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                Gestión de Calificaciones
            </h2>

            <small class="text-muted">
                Administración de notas de los estudiantes.
            </small>

        </div>

        <a asp-action="Registrar"
           class="btn btn-primary">

            <i class="bi bi-plus-circle me-1"></i>

            Nueva Calificación

        </a>

    </div>

    <div class="card shadow border-0">

        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">
                    No hay calificaciones registradas.
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-dark">

                            <tr>
                                <th>ID</th>
                                <th>Matrícula</th>
                                <th>Estudiante</th>
                                <th>Curso</th>
                                <th>Nota</th>
                                <th>Resultado</th>
                                <th>Fecha</th>
                                <th width="190">Acciones</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                var matricula =
                                    matriculas.FirstOrDefault(
                                        x => x.IdMatricula ==
                                             item.IdMatricula
                                    );

                                var estudiante = matricula == null
                                    ? null
                                    : estudiantes.FirstOrDefault(
                                        x => x.IdEstudiante ==
                                             matricula.IdEstudiante
                                    );

                                var curso = matricula == null
                                    ? null
                                    : cursos.FirstOrDefault(
                                        x => x.IdCurso ==
                                             matricula.IdCurso
                                    );

                                <tr>

                                    <td>
                                        @item.IdCalificacion
                                    </td>

                                    <td>
                                        #@item.IdMatricula
                                    </td>

                                    <td>

                                        @if (estudiante != null)
                                        {
                                            <span>
                                                @estudiante.Nombre
                                                @estudiante.PrimerApellido
                                                @estudiante.SegundoApellido
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                Sin información
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (curso != null)
                                        {
                                            @curso.NombreCurso
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                Sin información
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        <strong>
                                            @item.Nota.ToString("0.##")
                                        </strong>
                                    </td>

                                    <td>

                                        @if (item.Nota >= 70)
                                        {
                                            <span class="badge bg-success">
                                                Aprobado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Reprobado
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        @item.FechaRegistro.ToString(
                                            "dd/MM/yyyy"
                                        )
                                    </td>

                                    <td>

                                        <a asp-action="Editar"
                                           asp-route-id="@item.IdCalificacion"
                                           class="btn btn-warning btn-sm">

                                            <i class="bi bi-pencil-square"></i>

                                            Editar

                                        </a>

                                        <a asp-action="Eliminar"
                                           asp-route-id="@item.IdCalificacion"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('¿Desea eliminar esta calificación?')">

                                            <i class="bi bi-trash"></i>

                                            Eliminar

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>
