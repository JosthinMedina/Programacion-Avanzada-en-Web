@model IEnumerable<SistemaGestionAcademica.Web.Models.Curso>

@using SistemaGestionAcademica.Web.Models

@{
    ViewData["Title"] = "Cursos";

    var profesores =
        ViewBag.Profesores as List<Profesor>
        ?? new List<Profesor>();
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Cursos</h2>

    <a asp-action="Registrar"
       class="btn btn-primary">

        <i class="bi bi-plus-circle me-1"></i>

        Nuevo Curso

    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No hay cursos registrados.
    </div>
}
else
{
    <div class="table-responsive">

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>ID</th>
                    <th>Curso</th>
                    <th>Profesor</th>
                    <th>Descripción</th>
                    <th>Estado</th>
                    <th>Fecha de registro</th>
                    <th style="width: 180px;">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    var profesor = profesores.FirstOrDefault(
                        x => x.IdProfesor == item.IdProfesor
                    );

                    <tr>

                        <td>@item.IdCurso</td>

                        <td>@item.NombreCurso</td>

                        <td>
                            @if (profesor != null)
                            {
                                <span>
                                    @profesor.Nombre
                                    @profesor.PrimerApellido
                                    @profesor.SegundoApellido
                                </span>
                            }
                            else
                            {
                                <span>
                                    Profesor #@item.IdProfesor
                                </span>
                            }
                        </td>

                        <td>@item.Descripcion</td>

                        <td>

                            @if (item.Estado)
                            {
                                <span class="badge bg-success">
                                    Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactivo
                                </span>
                            }

                        </td>

                        <td>
                            @item.FechaRegistro.ToString("dd/MM/yyyy")
                        </td>

                        <td>

                            <a asp-action="Editar"
                               asp-route-id="@item.IdCurso"
                               class="btn btn-warning btn-sm">

                                <i class="bi bi-pencil-square"></i>

                                Editar

                            </a>

                            <a asp-action="Eliminar"
                               asp-route-id="@item.IdCurso"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('¿Desea eliminar este curso?')">

                                <i class="bi bi-trash"></i>

                                Eliminar

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
}
